{% extends 'base.twig' %}

{% block content %}
<div class="admin-page-shell">
  {% include 'admin/page-shell.twig' with {
    sidebar_title: lang.edit.title|default('Edit')
  } %}

  <div class="admin-page-main">
    {% include 'shared/topbar.twig' with { topbar_title: lang.edit.title|default('Edit') } %}
    <section class="admin-page-hero">
      <div>
        <a href="{{ return_to }}" class="edit-back-link"><i class="bi bi-arrow-left me-1"></i>{{ lang.edit.previous }}</a>
        <h1 class="admin-page-title">{{ lang.edit.title }}</h1>
      </div>
    </section>

    <div class="admin-page-content admin-page-stack">
      <div class="card">
        <div class="card-body">
          {% block inner_content %}
            {% if access_denied %}
            <div class="alert alert-danger" role="alert">{{ lang.danger.access_denied }}</div>
            {% else %}
            <div class="alert alert-info" role="alert">{{ lang.info.no_action }}</div>
            {% endif %}
          {% endblock %}
        </div>
      </div>
    </div>
  </div>
</div>

<script type='text/javascript'>
  var lang_user = {{ lang_user|raw }};
  var lang_admin = {{ lang_admin|raw }};
  var lang_datatables = {{ lang_datatables|raw }};
  var csrf_token = '{{ csrf_token }}';
  var pagination_size = Math.trunc('{{ pagination_size }}');
  var table_for_domain = '{{ domain }}';
</script>
{% endblock %}

{% extends 'base.twig' %}

{% block content %}
<div class="admin-page-shell">
  {% include 'admin/page-shell.twig' with {
    sidebar_kicker: 'Domain workspace',
    sidebar_title: 'Settings'
  } %}

  <div class="admin-page-main">
    {% include 'shared/topbar.twig' with { topbar_title: 'Domain admin settings' } %}
    <section class="admin-page-hero">
      <div>
        <p class="dashboard-kicker">Domain admin settings</p>
        <h1 class="admin-page-title">Account Studio</h1>
      </div>
    </section>

    <div class="admin-page-content admin-page-stack domain-settings-page">
      <section class="settings-hero-band" aria-label="Account summary">
        <div class="settings-hero-chip">
          <span>Signed in as</span>
          <strong>{{ mailcow_cc_username }}</strong>
        </div>
        <div class="settings-hero-chip">
          <span>Role</span>
          <strong>Domain administrator</strong>
        </div>
        <div class="settings-hero-chip">
          <span>Two-factor status</span>
          <strong>{{ tfa_data.pretty }}</strong>
        </div>
      </section>

      <section class="settings-section settings-section-profile">
        <div class="settings-section-heading">
          <p class="dashboard-kicker">{{ lang.user.user_settings }}</p>
          <h2>Profile</h2>
        </div>
        <div class="settings-grid settings-grid-profile">
          <div class="settings-panel">
            <span class="settings-label">Password</span>
            <div class="settings-action-card">
              <h3>{{ lang.user.change_password }}</h3>
              <a class="btn btn-primary settings-primary-link" href="#pwChangeModal" data-bs-toggle="modal">{{ lang.user.change_password }}</a>
            </div>
          </div>
          <div class="settings-panel">
            <span class="settings-label">Recent activity</span>
            <div class="settings-action-card settings-action-card-activity">
              <div class="last-ui-login"></div>
              <button type="button" class="btn settings-inline-button clear-last-logins">{{ lang.user.clear_recent_successful_connections }}</button>
            </div>
          </div>
        </div>
      </section>

      <section class="settings-section">
        <div class="settings-section-heading">
          <p class="dashboard-kicker">{{ lang.tfa.tfa }}</p>
          <h2>Authentication</h2>
        </div>
        <div class="settings-grid settings-grid-security">
          <div class="settings-panel">
            <span class="settings-label">Current status</span>
            <div class="settings-status-card">
              <div id="tfa_pretty" class="settings-status-value">{{ tfa_data.pretty }}</div>
              {% include 'tfa_keys.twig' %}
            </div>
          </div>
          <div class="settings-panel">
            <span class="settings-label">{{ lang.tfa.set_tfa }}</span>
            <div class="settings-control-card">
              <label class="settings-field-caption" for="selectTFA">{{ lang.tfa.select }}</label>
              <select id="selectTFA" class="selectpicker" title="{{ lang.tfa.select }}">
                <option value="yubi_otp">{{ lang.tfa.yubi_otp }}</option>
                <option value="webauthn">{{ lang.tfa.webauthn }}</option>
                <option value="totp">{{ lang.tfa.totp }}</option>
                <option value="none">{{ lang.tfa.none }}</option>
              </select>
            </div>
          </div>
        </div>
      </section>

      <section class="settings-section">
        <div class="settings-section-heading">
          <p class="dashboard-kicker">{{ lang.fido2.fido2_auth }}</p>
          <h2>Security keys</h2>
        </div>
        <div class="settings-grid settings-grid-fido">
          <div class="settings-panel settings-panel-wide">
            <span class="settings-label">{{ lang.fido2.known_ids }}</span>
            <div class="settings-table-card">
              <div class="table-responsive">
                <table class="table table-striped table-hover table-condensed w-100" id="fido2_keys">
                  <tr>
                    <th>ID</th>
                    <th style="min-width:240px;text-align: right">{{ lang.admin.action }}</th>
                  </tr>
                  {% include 'fido2.twig' %}
                </table>
              </div>
            </div>
          </div>
          <div class="settings-panel">
            <span class="settings-label">{{ lang.fido2.set_fido2 }}</span>
            <div class="settings-control-card settings-control-card-stack">
              <div class="btn-group settings-button-group">
                <button class="btn btn-sm btn-primary" id="register-fido2">{{ lang.fido2.set_fido2 }}</button>
                <button type="button" class="btn btn-sm btn-xs-lg btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false"></button>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="#" id="register-fido2-touchid"><i class="bi bi-shield-fill-check"></i> {{ lang.fido2.set_fido2_touchid }}</a></li>
                </ul>
              </div>
              <div id="status-fido2" class="settings-status-card settings-status-card-compact">
                <span class="settings-field-caption">{{ lang.fido2.register_status }}</span>
                <div id="fido2-alerts">-</div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
{% include 'user_domainadmin_common.twig' %}
{% endblock %}

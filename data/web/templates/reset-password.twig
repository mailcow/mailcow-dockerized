{% extends 'base.twig' %}

{% block navbar %}{% endblock %}

{% block content %}
<div class="reset-shell">
  <div class="reset-topbar">
    <div class="reset-brand">
      <img class="main-logo" alt="mailcow" src="{{ logo|default('/img/cow_mailcow.svg') }}" style="height:2rem;">
      <img class="main-logo-dark" alt="mailcow" src="{{ logo_dark|default('/img/cow_mailcow.svg') }}" style="height:2rem;">
    </div>
    <div class="reset-topbar-actions">
      <div class="form-check form-switch d-flex align-items-center gap-2 mb-0">
        <label class="form-check-label" style="color:var(--reset-ink-muted)"><i class="bi bi-moon-fill"></i></label>
        <input class="form-check-input" type="checkbox" id="dark-mode-toggle">
      </div>
    </div>
  </div>

  <div class="reset-form-panel">
    <div class="reset-form-panel-inner">
      <p class="reset-overline">{{ ui_texts.main_name|raw }}</p>
      <h1 class="reset-title">{{ lang.login.reset_password }}</h1>

      {% if is_reset_token_valid %}
      <form method="post" autofill="off" class="reset-form">
        <input type="hidden" name="token" value="{{ reset_token }}" />
        <div class="reset-field">
          <label class="reset-label">{{ lang.login.new_password }}</label>
          <input type="password" autocorrect="off" autocapitalize="none" class="form-control reset-input" name="new_password" placeholder="{{ lang.login.new_password }}" />
        </div>
        <div class="reset-field">
          <label class="reset-label">{{ lang.login.new_password_confirm }}</label>
          <input type="password" autocorrect="off" autocapitalize="none" class="form-control reset-input" name="new_password2" placeholder="{{ lang.login.new_password_confirm }}" />
        </div>
        <small id="mismatch_alert" class="text-danger d-none">{{ lang.login.password_mismatch }}</small>
        <button type="submit" class="reset-submit" name="pw_reset">{{ lang.login.reset_password }} <i class="bi bi-arrow-right ms-1"></i></button>
      </form>

      {% elseif reset_token is null %}
      <form method="post" autofill="off" class="reset-form">
        <div class="reset-field">
          <label class="reset-label">{{ lang.login.username }}</label>
          <input type="text" autocorrect="off" autocapitalize="none" class="form-control reset-input" name="username" placeholder="{{ lang.login.username }}" />
        </div>
        <button type="submit" class="reset-submit" name="pw_reset_request">{{ lang.login.request_reset_password }} <i class="bi bi-arrow-right ms-1"></i></button>
      </form>

      {% else %}
      <p class="reset-message">{{ lang.login.invalid_pass_reset_token|raw }}</p>
      {% endif %}

      <a href="/" class="reset-back-link"><i class="bi bi-arrow-left me-1"></i>{{ lang.login.back_to_mailcow }}</a>
    </div>
  </div>
</div>

<style>
  body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: #0f2524 !important;
    padding: 1.5rem;
  }
  .reset-shell {
    --reset-ink: #f7f0e5;
    --reset-ink-muted: rgba(247, 240, 229, 0.6);
    --reset-accent: #f4b548;
    --reset-accent-dark: #d9771e;
    --reset-form-ink: #1d2e2a;
    --reset-line: rgba(29, 46, 42, 0.14);
    display: grid;
    gap: 1rem;
    width: min(480px, 100%);
  }
  .reset-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.05);
  }
  .reset-form-panel {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 248, 239, 0.95);
    position: relative;
    overflow: hidden;
  }
  .reset-form-panel::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 0.3rem;
    background: var(--reset-accent);
  }
  .reset-form-panel-inner {
    padding: clamp(1.5rem, 4vw, 2rem);
  }
  .reset-overline {
    margin: 0 0 0.35rem;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--reset-accent-dark);
  }
  .reset-title {
    margin: 0 0 1.5rem;
    color: var(--reset-form-ink);
    font-family: "Palatino Linotype", "Book Antiqua", Georgia, serif;
    font-size: clamp(1.7rem, 5vw, 2.2rem);
    line-height: 1;
  }
  .reset-form {
    display: grid;
    gap: 1rem;
  }
  .reset-field {
    display: grid;
    gap: 0.4rem;
  }
  .reset-label {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--reset-form-ink);
  }
  .reset-input {
    min-height: 3.2rem;
    border: 1px solid var(--reset-line);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.92);
    color: var(--reset-form-ink);
    font-size: 1rem;
  }
  .reset-input:focus {
    border-color: rgba(217, 119, 30, 0.45);
    box-shadow: 0 0 0 3px rgba(244, 181, 72, 0.15);
    background: #fff;
  }
  .reset-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3.2rem;
    margin-top: 0.25rem;
    border: 0;
    border-radius: 0;
    background: var(--reset-accent);
    color: #182724;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background-color 180ms ease;
  }
  .reset-submit:hover,
  .reset-submit:focus {
    background: var(--reset-accent-dark);
    color: #182724;
  }
  .reset-back-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: #2d6d67;
    text-decoration: none;
    border-bottom: 1px solid rgba(45, 109, 103, 0.25);
  }
  .reset-back-link:hover {
    color: #194c47;
    border-bottom-color: currentColor;
  }
  .reset-message {
    color: #6b4a3a;
    margin-bottom: 1rem;
  }
</style>

<script type='text/javascript'>
  var csrf_token = '{{ csrf_token }}';
  var mailcow_cc_username = '{{ mailcow_cc_username }}';
</script>
{% endblock %}

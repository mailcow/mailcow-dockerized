{% extends 'base.twig' %}

{% block content %}
{% set running_containers = 0 %}
{% for container, container_info in containers %}
  {% if container_info.State.Running == 1 %}
    {% set running_containers = running_containers + 1 %}
  {% endif %}
{% endfor %}
{% set total_containers = containers|length %}
{% set stopped_containers = total_containers - running_containers %}
{% set dashboard_status = stopped_containers > 0 ? 'Action needed' : 'Healthy' %}
{% set dashboard_status_class = stopped_containers > 0 ? 'is-warning' : 'is-healthy' %}

<div class="admin-page-shell dashboard-shell">
  {% include 'admin/page-shell.twig' with {
    sidebar_kicker: 'Admin command center',
    sidebar_title: hostname,
    sidebar_copy: 'A compact overview of system health, queue pressure, and the admin paths you are most likely to need next.',
    sidebar_metrics: [
      {'label': 'Status', 'value': dashboard_status},
      {'label': lang.debug.container_running, 'value': running_containers},
      {'label': lang.debug.disk_usage, 'value': vmail_df[4]},
      {'label': lang.debug.timezone, 'value': timezone}
    ]
  } %}

  <div class="dashboard-main">
    {% include 'shared/topbar.twig' with {
      topbar_title: 'Runtime overview',
      topbar_status: dashboard_status,
      topbar_status_class: stopped_containers > 0 ? 'warn' : 'ok'
    } %}
    <section class="dashboard-command-bar">
      <div class="dashboard-command-copy">
        <div class="dashboard-status-pill {{ dashboard_status_class }}">{{ dashboard_status }}</div>
        <p class="dashboard-kicker">Runtime overview</p>
        <h2 class="dashboard-title">{{ hostname }} command center</h2>
        <p class="dashboard-subtitle">See the health story first, jump to the admin surface you need, and open deeper logs only when you actually need them.</p>
      </div>
      <div class="dashboard-command-actions">
        <a class="dashboard-primary-button" href="/admin/system">System settings</a>
        <a class="dashboard-action-button" href="/admin/mailbox">Mail</a>
        <a class="dashboard-action-button" href="/admin/queue">Queue</a>
        <a class="dashboard-action-button" href="/quarantine">Quarantine</a>
      </div>
    </section>

    <section class="dashboard-hero">
      <div class="dashboard-hero-grid">
        <div class="dashboard-stat-card dashboard-stat-card-emphasis">
          <span class="dashboard-stat-label">Containers</span>
          <strong class="dashboard-stat-value">{{ total_containers }}</strong>
          <small>{{ running_containers }} running</small>
        </div>
        <div class="dashboard-stat-card">
          <span class="dashboard-stat-label">{{ lang.debug.disk_usage }}</span>
          <strong class="dashboard-stat-value">{{ vmail_df[4] }}</strong>
          <small>{{ vmail_df[2] }} used</small>
        </div>
        <div class="dashboard-stat-card">
          <span class="dashboard-stat-label">Version</span>
          <strong class="dashboard-stat-value">{{ mailcow_info.version_tag }}</strong>
          <small>{{ timezone }}</small>
        </div>
        <div class="dashboard-stat-card">
          <span class="dashboard-stat-label">{{ lang.admin.guid }}</span>
          <strong class="dashboard-stat-value">{{ gal.c|default('?') }}</strong>
          <small>{% if gal.valid == true %}License active{% else %}Validation pending{% endif %}</small>
        </div>
      </div>
    </section>

    <nav class="nav nav-tabs dashboard-switchboard" role="tablist" aria-label="Dashboard views">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-containers" type="button" role="tab" aria-controls="tab-containers" aria-selected="true">Overview</button>
      <div class="nav-item dropdown">
        <button class="nav-link dropdown-toggle" data-bs-toggle="dropdown" type="button" aria-expanded="false">Service logs</button>
        <ul class="dropdown-menu">
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-postfix-logs" type="button" role="tab" aria-controls="tab-postfix-logs">Postfix</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-dovecot-logs" type="button" role="tab" aria-controls="tab-dovecot-logs">Dovecot</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-sogo-logs" type="button" role="tab" aria-controls="tab-sogo-logs">SOGo</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-netfilter-logs" type="button" role="tab" aria-controls="tab-netfilter-logs">Netfilter</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-autodiscover-logs" type="button" role="tab" aria-controls="tab-autodiscover-logs">Autodiscover</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-watchdog-logs" type="button" role="tab" aria-controls="tab-watchdog-logs">Watchdog</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-acme-logs" type="button" role="tab" aria-controls="tab-acme-logs">ACME</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-api-logs" type="button" role="tab" aria-controls="tab-api-logs">API</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-api-rl" type="button" role="tab" aria-controls="tab-api-rl">Ratelimits</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-cron-logs" type="button" role="tab" aria-controls="tab-cron-logs">Crontasks</button></li>
        </ul>
      </div>
      <div class="nav-item dropdown">
        <button class="nav-link dropdown-toggle" data-bs-toggle="dropdown" type="button" aria-expanded="false">Observability</button>
        <ul class="dropdown-menu">
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-rspamd-history" type="button" role="tab" aria-controls="tab-rspamd-history">Rspamd</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-ui" type="button" role="tab" aria-controls="tab-ui">Mailcow UI</button></li>
          <li><button class="dropdown-item" data-bs-toggle="tab" data-bs-target="#tab-sasl" type="button" role="tab" aria-controls="tab-sasl">SASL</button></li>
        </ul>
      </div>
    </nav>

    <div class="tab-content dashboard-tab-content">
      <div role="tabpanel" class="tab-pane active" id="tab-containers">
        <div class="card dashboard-overview-card mb-4">
          <div class="card-body">
            <div class="dashboard-command-grid">
              <section class="dashboard-focus-card">
                <div class="dashboard-panel-head">
                  <div>
                    <p class="dashboard-kicker">Health overview</p>
                    <h3>Priority snapshot</h3>
                  </div>
                </div>
                <div class="dashboard-health-grid">
                  <div class="dashboard-detail-card">
                    <span>Status</span>
                    <strong>{{ dashboard_status }}</strong>
                    <small>{% if stopped_containers > 0 %}One or more services need attention.{% else %}Core runtime services are up.{% endif %}</small>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>Hostname</span>
                    <strong>{{ hostname }}</strong>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>{{ lang.debug.architecture }}</span>
                    <strong id="host_architecture">-</strong>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>Version</span>
                    <strong><a href="#" id="mailcow_version">{{ mailcow_info.version_tag }}</a></strong>
                    <small id="mailcow_update"></small>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>{{ lang.debug.container_running }}</span>
                    <strong>{{ running_containers }}</strong>
                    <small>{{ stopped_containers }} stopped</small>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>{{ lang.debug.timezone }}</span>
                    <strong>{{ timezone }}</strong>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>{{ lang.debug.current_time }}</span>
                    <strong id="host_date">-</strong>
                  </div>
                  <div class="dashboard-detail-card">
                    <span>{{ lang.debug.uptime }}</span>
                    <strong id="host_uptime">-</strong>
                  </div>
                  <div class="dashboard-detail-card dashboard-detail-card-wide">
                    <span>IPs</span>
                    <div class="dashboard-ip-block">
                      {% if ip_check == 1 %}
                        <button class="btn dashboard-action-button" id="host_show_ip">
                          <span class="text">{{ lang.debug.show_ip }}</span>
                          <div class="spinner-border spinner-border-sm d-none" role="status">
                            <span class="visually-hidden">Loading...</span>
                          </div>
                        </button>
                        <span class="d-none" id="host_ipv4">-</span>
                        <span class="d-none" id="host_ipv6">-</span>
                      {% else %}
                        <span>{{ lang.admin.ip_check_disabled|raw }}</span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="dashboard-detail-card dashboard-detail-card-wide">
                    <span>{{ lang.debug.disk_usage }}</span>
                    <div class="dashboard-storage-meta">
                      <strong><i class="bi bi-hdd-stack-fill"></i> {{ vmail_df[0] }}</strong>
                      <small>{{ vmail_df[2] }} / {{ vmail_df[1] }} ({{ vmail_df[4] }})</small>
                    </div>
                    <div class="progress dashboard-storage-progress-wrap">
                      <div class="progress-bar dashboard-storage-progress" role="progressbar" style="width:{{ vmail_df[4] }}"></div>
                    </div>
                  </div>
                </div>
              </section>

              <section class="dashboard-focus-card">
                <div class="dashboard-panel-head">
                  <div>
                    <p class="dashboard-kicker">Operator actions</p>
                    <h3>Go straight to work</h3>
                  </div>
                </div>
                <div class="dashboard-action-grid">
                  <a class="dashboard-quick-card" href="/admin/system">
                    <span class="dashboard-kicker">Configuration</span>
                    <strong>System</strong>
                    <small>Access, policies, customization, and routing.</small>
                  </a>
                  <a class="dashboard-quick-card" href="/admin/mailbox">
                    <span class="dashboard-kicker">Mail flow</span>
                    <strong>Mailbox manager</strong>
                    <small>Domains, mailboxes, aliases, and filters.</small>
                  </a>
                  <a class="dashboard-quick-card" href="/admin/queue">
                    <span class="dashboard-kicker">Delivery</span>
                    <strong>Queue manager</strong>
                    <small>Inspect and unblock delayed mail quickly.</small>
                  </a>
                  <a class="dashboard-quick-card" href="/quarantine">
                    <span class="dashboard-kicker">Security</span>
                    <strong>Quarantine center</strong>
                    <small>Review held mail and release what matters.</small>
                  </a>
                </div>
              </section>
            </div>

            <div class="row g-4 align-items-stretch">
              <div class="col-lg-6">
                <div class="dashboard-chart-card">
                  <div class="dashboard-panel-head">
                    <div>
                      <p class="dashboard-kicker">Runtime</p>
                      <h3>CPU</h3>
                    </div>
                    <div class="dashboard-chart-meta"><span id="host_cpu_cores">-</span> {{ lang.debug.cores }} @ <span id="host_cpu_usage"></span></div>
                  </div>
                  <canvas id="host_cpu_chart" width="400" height="200"></canvas>
                </div>
              </div>

              <div class="col-lg-6">
                <div class="dashboard-chart-card">
                  <div class="dashboard-panel-head">
                    <div>
                      <p class="dashboard-kicker">Runtime</p>
                      <h3>{{ lang.debug.memory|upper }}</h3>
                    </div>
                    <div class="dashboard-chart-meta"><span id="host_memory_total">-</span> @ <span id="host_memory_usage"></span></div>
                  </div>
                  <canvas id="host_mem_chart" width="400" height="200"></canvas>
                </div>
              </div>

              <div class="col-xl-6">
                <div class="dashboard-license-card dashboard-runtime-card">
                  <div class="dashboard-panel-head">
                    <div>
                      <p class="dashboard-kicker">Identity</p>
                      <h3>Platform and license</h3>
                    </div>
                  </div>
                  <div class="dashboard-license-meta">
                    <span>{{ lang.admin.customer_id }}: {{ gal.c|default('?')|raw }}</span>
                    <span>{{ lang.admin.service_id }}: {{ gal.s|default('?')|raw }}</span>
                    <span>{{ lang.admin.sal_level }}: {{ gal.m|default('?')|raw }}</span>
                  </div>
                  <div class="dashboard-license-summary">
                    <div class="dashboard-detail-card">
                      <span>{{ lang.admin.guid }}</span>
                      <strong>{{ license_guid }}</strong>
                    </div>
                    <div class="dashboard-detail-card">
                      <span>Validation</span>
                      <strong>{% if gal.valid == true %}Active{% else %}Pending{% endif %}</strong>
                    </div>
                  </div>
                  <button class="btn dashboard-primary-button" name="license_validate_now" type="submit" form="dashboard-license-form">{{ lang.admin.validate_license_now }}</button>
                </div>
              </div>

              <div class="col-xl-6">
                <div class="dashboard-runtime-card">
                  <div class="dashboard-panel-head">
                    <div>
                      <p class="dashboard-kicker">Workspace</p>
                      <h3>What this page covers</h3>
                    </div>
                  </div>
                  <div class="dashboard-action-grid dashboard-action-grid-compact">
                    <div class="dashboard-quick-card dashboard-quick-card-static">
                      <span class="dashboard-kicker">Runtime</span>
                      <strong>CPU and memory</strong>
                      <small>Live usage trends for the current host.</small>
                    </div>
                    <div class="dashboard-quick-card dashboard-quick-card-static">
                      <span class="dashboard-kicker">Services</span>
                      <strong>Container fleet</strong>
                      <small>Restart services and inspect per-container I/O.</small>
                    </div>
                    <div class="dashboard-quick-card dashboard-quick-card-static">
                      <span class="dashboard-kicker">Logs</span>
                      <strong>Operational history</strong>
                      <small>Switch views from the tabs above instead of the sidebar.</small>
                    </div>
                    <div class="dashboard-quick-card dashboard-quick-card-static">
                      <span class="dashboard-kicker">Identity</span>
                      <strong>Version and license</strong>
                      <small>Platform verification and release visibility.</small>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-12">
                <div class="dashboard-license-card" id="license">
                  <div class="dashboard-panel-head">
                    <div>
                      <p class="dashboard-kicker">{{ lang.admin.guid_and_license }}</p>
                      <h3>License & identity</h3>
                    </div>
                  </div>
                  <form class="form-horizontal" autocapitalize="none" autocorrect="off" role="form" method="post" id="dashboard-license-form">
                    <div class="row g-4 align-items-start">
                      <div class="col-lg-7">
                        <label class="dashboard-field-label" for="guid">{{ lang.admin.guid }}</label>
                        <div class="input-group">
                          <span class="input-group-text">
                            <i class="bi bi-suit-heart{% if gal.valid == true %}-fill text-danger{% endif %}"></i>
                          </span>
                          <input type="text" id="guid" class="form-control" value="{{ license_guid }}" readonly>
                        </div>
                      </div>
                      <div class="col-lg-5">
                        <div class="dashboard-license-meta">
                          <span>{{ lang.admin.customer_id }}: {{ gal.c|default('?')|raw }}</span>
                          <span>{{ lang.admin.service_id }}: {{ gal.s|default('?')|raw }}</span>
                          <span>{{ lang.admin.sal_level }}: {{ gal.m|default('?')|raw }}</span>
                        </div>
                      </div>
                      <div class="col-12">
                        <p class="text-muted">{{ lang.admin.license_info|raw }}</p>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card dashboard-containers-card mb-4">
          <div class="card-header">
            <div class="dashboard-panel-head mb-0">
              <div>
                <p class="dashboard-kicker">{{ lang.debug.containers_info }}</p>
                <h3>Service runtime cards</h3>
              </div>
              <div class="dashboard-panel-meta">{{ running_containers }} running / {{ stopped_containers }} stopped</div>
            </div>
          </div>
          <div class="card-body">
            <div class="row g-3">
              {% for container, container_info in containers %}
                <div class="col-xl-6">
                  <div class="dashboard-container-card {% if container_info.State.Running == 1 %}is-running{% else %}is-stopped{% endif %}">
                    <div class="dashboard-container-head">
                      <div>
                        <div class="dashboard-container-title-row">
                          <span class="dashboard-container-title">{{ container }}</span>
                          {% if container_info.State.Running == 1 %}
                            <span class="badge fs-7 bg-success loader">
                              {{ lang.debug.container_running }}
                              <span class="loader-dot">.</span>
                              <span class="loader-dot">.</span>
                              <span class="loader-dot">.</span>
                            </span>
                          {% elseif container_info.State %}
                            <span class="badge fs-7 bg-danger">
                              {{ lang.debug.container_stopped }}
                              <i class="bi-x ms-1"></i>
                            </span>
                          {% endif %}
                        </div>
                        <span class="dashboard-container-image">{{ container_info.Config.Image }}</span>
                        <small>{{ lang.debug.started_on }} <span class="parse_date">{{ container_info.State.StartedAtHR }}</span></small>
                      </div>
                      <button class="btn dashboard-icon-button" type="button" data-bs-toggle="collapse" data-bs-target="#{{ container }}Collapse" aria-expanded="false" aria-controls="{{ container }}Collapse">
                        <i class="bi bi-caret-down-fill caret"></i>
                      </button>
                    </div>
                    <div class="collapse container-details-collapse" id="{{ container }}Collapse" data-id="{{ container_info.Id }}">
                      <div class="row g-3 pt-4">
                        <div class="col-md-6 d-flex flex-column">
                          <h6>Disk I/O</h6>
                          <div class="spinner-border my-4 mx-auto" role="status">
                            <span class="visually-hidden">Loading...</span>
                          </div>
                          <canvas class="d-none" id="{{ container }}_DiskIOChart" width="400" height="200"></canvas>
                        </div>
                        <div class="col-md-6 d-flex flex-column">
                          <h6>Net I/O</h6>
                          <div class="spinner-border my-4 mx-auto" role="status">
                            <span class="visually-hidden">Loading...</span>
                          </div>
                          <canvas class="d-none" id="{{ container }}_NetIOChart" width="400" height="200"></canvas>
                        </div>
                        <div class="col-12 d-flex">
                          <a href data-bs-toggle="modal"
                            data-container="{{ container }}"
                            data-bs-target="#RestartContainer"
                            class="btn dashboard-action-button ms-auto">{{ lang.debug.restart_container }}
                            <i class="ms-1 bi {% if container_info.State.Running == 1 %}bi-record-fill text-success{% elseif container_info.State %}bi-record-fill text-danger{% else %}default{% endif %}"></i>
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>

      <div role="tabpanel" class="tab-pane" id="tab-postfix-logs">
        <div class="debug-log-info">{{ lang.debug.log_info|format(log_lines+1)|raw }}</div>
        <div class="card">
          <div class="card-header d-flex align-items-center fs-5">
            <span class="mt-2 ms-2">Postfix</span>
            <div class="btn-group ms-auto">
              <button class="btn btn-sm btn-secondary refresh_table" data-draw="draw_postfix_logs" data-table="postfix_log">{{ lang.admin.refresh }}</button>
            </div>
          </div>
          <div class="card-body">
            <a class="btn btn-sm btn-secondary dropdown-toggle mb-4" data-bs-toggle="dropdown" href="#">{{ lang.mailbox.quick_actions }}</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item add_log_lines" data-post-process="general_syslog" data-table="postfix_log" data-log-url="postfix" data-nrows="100" href="#">+ 100</a></li>
              <li><a class="dropdown-item add_log_lines" data-post-process="general_syslog" data-table="postfix_log" data-log-url="postfix" data-nrows="1000" href="#">+ 1000</a></li>
              <li class="table_collapse_option"><hr class="dropdown-divider"></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-expand="postfix_log" data-table="postfix_log" href="#">{{ lang.datatables.expand_all }}</a></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-collapse="postfix_log" data-table="postfix_log" href="#">{{ lang.datatables.collapse_all }}</a></li>
            </ul>
            <table id="postfix_log" class="table table-striped dt-responsive w-100"></table>
          </div>
        </div>
      </div>

      <div role="tabpanel" class="tab-pane" id="tab-ui">
        <div class="debug-log-info">{{ lang.debug.log_info|format(log_lines+1)|raw }}</div>
        <div class="card">
          <div class="card-header d-flex align-items-center fs-5">
            <span class="mt-2 ms-2">Mailcow UI</span>
            <div class="btn-group ms-auto">
              <button class="btn btn-sm btn-secondary refresh_table" data-draw="draw_ui_logs" data-table="ui_logs">{{ lang.admin.refresh }}</button>
            </div>
          </div>
          <div class="card-body">
            <a class="btn btn-sm btn-secondary dropdown-toggle mb-4" data-bs-toggle="dropdown" href="#">{{ lang.mailbox.quick_actions }}</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item add_log_lines" data-post-process="mailcow_ui" data-table="ui_logs" data-log-url="ui" data-nrows="100" href="#">+ 100</a></li>
              <li><a class="dropdown-item add_log_lines" data-post-process="mailcow_ui" data-table="ui_logs" data-log-url="ui" data-nrows="1000" href="#">+ 1000</a></li>
              <li class="table_collapse_option"><hr class="dropdown-divider"></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-expand="ui_logs" data-table="ui_logs" href="#">{{ lang.datatables.expand_all }}</a></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-collapse="ui_logs" data-table="ui_logs" href="#">{{ lang.datatables.collapse_all }}</a></li>
            </ul>
            <table id="ui_logs" class="table table-striped dt-responsive w-100"></table>
          </div>
        </div>
      </div>

      <div role="tabpanel" class="tab-pane" id="tab-sasl">
        <div class="debug-log-info">{{ lang.debug.log_info|format(log_lines+1)|raw }}</div>
        <div class="card">
          <div class="card-header d-flex align-items-center fs-5">
            <span class="mt-2 ms-2">SASL</span>
            <div class="btn-group ms-auto">
              <button class="btn btn-sm btn-secondary refresh_table" data-draw="draw_sasl_logs" data-table="sasl_logs">{{ lang.admin.refresh }}</button>
            </div>
          </div>
          <div class="card-body">
            <a class="btn btn-sm btn-secondary dropdown-toggle mb-4" data-bs-toggle="dropdown" href="#">{{ lang.mailbox.quick_actions }}</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item add_log_lines" data-post-process="sasl_log_table" data-table="sasl_logs" data-log-url="ui" data-nrows="100" href="#">+ 100</a></li>
              <li><a class="dropdown-item add_log_lines" data-post-process="sasl_log_table" data-table="sasl_logs" data-log-url="ui" data-nrows="1000" href="#">+ 1000</a></li>
              <li class="table_collapse_option"><hr class="dropdown-divider"></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-expand="sasl_logs" data-table="sasl_logs" href="#">{{ lang.datatables.expand_all }}</a></li>
              <li class="table_collapse_option"><a class="dropdown-item" data-datatables-collapse="sasl_logs" data-table="sasl_logs" href="#">{{ lang.datatables.collapse_all }}</a></li>
            </ul>
            <table id="sasl_logs" class="table table-striped dt-responsive w-100"></table>
          </div>
        </div>

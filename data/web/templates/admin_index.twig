{% extends 'base.twig' %}

{% block navbar %}{% endblock %}

{% block content %}
<div class="login-shell login-shell-single login-shell-admin">
  <div class="login-topbar">
    <div class="login-host-badge">
      <i class="bi bi-envelope-fill"></i>
      <span>{{ mailcow_hostname }}</span>
    </div>
    <div class="login-toolbar">
      <div class="form-check form-switch my-auto d-flex align-items-center login-theme-toggle">
        <label class="form-check-label" for="dark-mode-toggle"><i class="bi bi-moon-fill"></i></label>
        <input class="form-check-input ms-2" type="checkbox" id="dark-mode-toggle">
      </div>
      <div class="login-language-picker">
        <button type="button" {% if available_languages|length == 1 %}disabled="true"{% endif %} class="btn login-language-button dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
          <span class="flag-icon flag-icon-{{ mailcow_locale[-2:] }}"></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end login">
          {% for key, val in available_languages %}
            <li>
              <a class="dropdown-item {% if mailcow_locale == key %}active{% endif %}" href="?{{ query_string({'lang': key}) }}">
                <span class="flag-icon flag-icon-{{ key[-2:] }}"></span>{{ val }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

  <div class="login-stage">
    <section class="login-form-panel">
      <div class="login-panel-heading">
        <p class="login-panel-kicker">{{ lang.login.login_admin }}</p>
        <h1 class="login-panel-title">{{ lang.login.login }}</h1>
        <p class="login-panel-subtitle">{{ ui_texts.main_name|raw }}</p>
      </div>

      {% if ui_texts.ui_announcement_text and ui_texts.ui_announcement_active %}
      <div class="login-callout alert alert-{{ ui_texts.ui_announcement_type }} rot-enc ui-announcement-alert">{{ ui_texts.ui_announcement_text|rot13 }}</div>
      {% endif %}

      <div class="login-panel-layout">
        <form method="post" autofill="off" class="login-form">
          <div class="login-field">
            <label class="login-field-label" for="login_user">{{ lang.login.username }}</label>
            <div class="input-group login-input-group">
              <div class="input-group-text"><i class="bi bi-person-fill"></i></div>
              <input name="login_user" autocorrect="off" autocapitalize="none" type="text" id="login_user" class="form-control" placeholder="{{ lang.login.username }}" required="" autofocus="" autocomplete="username">
            </div>
          </div>

          <div class="login-field">
            <label class="login-field-label" for="pass_user">{{ lang.login.password }}</label>
            <div class="input-group login-input-group">
              <div class="input-group-text"><i class="bi bi-lock-fill"></i></div>
              <input name="pass_user" type="password" id="pass_user" class="form-control" placeholder="{{ lang.login.password }}" required="" autocomplete="current-password">
            </div>
          </div>

          <button type="submit" class="btn login-submit-button" value="Login">
            <span>{{ lang.login.login }}</span>
            <i class="bi bi-arrow-right-circle-fill"></i>
          </button>
        </form>

        <div class="login-panel-sidebar">
          <div class="login-alt-auth">
            <p class="login-alt-auth-title">{{ lang.login.other_logins }}</p>
            <div class="login-alt-auth-actions">
              <a class="btn btn-secondary login-auth-option" href="#" id="fido2-login">
                <i class="bi bi-shield-fill-check"></i>
                <span>{{ lang.login.fido2_webauthn }}</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      {% if login_delay %}
      <div class="alert alert-info login-delay-alert">{{ lang.login.delayed|format(login_delay) }}</div>
      {% endif %}

      <div class="my-4" id="fido2-alerts"></div>
    </section>
  </div>

  {% if custom_login.hide_user_quicklink != 1 or custom_login.hide_domainadmin_quicklink != 1 %}
  <div class="login-role-switcher login-role-switcher-compact">
    <span class="login-role-label">{{ lang.login.login_linkstext }}</span>
    <div class="login-role-links">
      {% if custom_login.hide_user_quicklink != 1 %}<a href="/">{{ lang.login.login_usertext }}</a>{% endif %}
      {% if custom_login.hide_domainadmin_quicklink != 1 %}<a href="/domainadmin">{{ lang.login.login_domainadmintext }}</a>{% endif %}
    </div>
  </div>
  {% endif %}
</div>
{% endblock %}

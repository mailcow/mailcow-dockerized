<script type='text/javascript'>
  var lang = {{ lang_admin|raw }};
  var lang_debug = {{ lang_debug|raw }};
  var lang_datatables = {{ lang_datatables|raw }};
  var csrf_token = '{{ csrf_token }}';
  var log_pagination_size = Math.trunc('{{ log_pagination_size }}');

  document.addEventListener('shown.bs.tab', function(event) {
    var target = event.target.getAttribute('data-bs-target');
    if (!target) {
      return;
    }

    document.querySelectorAll('.dashboard-switchboard > .nav-link').forEach(function(link) {
      var isMatch = link.getAttribute('data-bs-target') === target;
      link.classList.toggle('active', isMatch);
      link.setAttribute('aria-selected', isMatch ? 'true' : 'false');
    });

    document.querySelectorAll('.dashboard-switchboard .dropdown-item').forEach(function(item) {
      item.classList.toggle('active', item.getAttribute('data-bs-target') === target);
    });

    document.querySelectorAll('.dashboard-switchboard .dropdown-toggle').forEach(function(toggle) {
      toggle.classList.remove('active');
    });

    var activeDropdownItem = document.querySelector('.dashboard-switchboard .dropdown-item.active');
    if (activeDropdownItem) {
      var dropdown = activeDropdownItem.closest('.dropdown');
      if (dropdown) {
        var toggle = dropdown.querySelector('.dropdown-toggle');
        if (toggle) {
          toggle.classList.add('active');
        }
      }
    }
  });
</script>
